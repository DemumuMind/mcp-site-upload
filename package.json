{
  "name": "demumumind-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "typescript-eslint": "8.56.1",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript-eslint/typescript-estree": "8.56.1",
    "@typescript-eslint/utils": "8.56.1"
  },
  "scripts": {
    "predev": "node scripts/patch-contentlayer-win-warning.mjs",
    "dev": "node scripts/dev-with-env.mjs -p 3000",
    "prebuild": "node scripts/patch-contentlayer-win-warning.mjs",
    "build": "node scripts/run-build.mjs",
    "start": "node scripts/start-with-env.mjs",
    "content:build": "node scripts/run-content-build.mjs",
    "check:utf8": "node scripts/check-utf8.mjs",
    "check:utf8:strict": "node scripts/check-utf8.mjs --strict-missing",
    "check:api-docs": "node scripts/check-api-docs.mjs",
    "check:api-discipline": "node scripts/check-api-change-discipline.mjs",
    "check:cache-discipline": "node scripts/check-cache-discipline.mjs",
    "check:migrations": "node scripts/check-migration-prefixes.mjs",
    "check:cycles": "node scripts/check-import-cycles.mjs",
    "lint": "eslint .",
    "blog:new": "node scripts/blog-new-post.mjs",
    "blog:migrate-mdx": "node scripts/blog-migrate-json-to-mdx.mjs",
    "catalog:count:guard": "node scripts/catalog-count-guard.mjs",
    "verify:dashboard:metrics": "node scripts/verify-dashboard-metrics.mjs",
    "profile:multi-agent": "node scripts/profile-multi-agent.mjs",
    "git:scope-status": "node scripts/git-scope-status.mjs",
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "test": "node scripts/run-playwright.mjs",
    "test:e2e": "node scripts/run-playwright.mjs",
    "test:e2e:admin:local": "node scripts/run-playwright-admin-local.mjs",
    "test:e2e:auth": "node scripts/check-supabase-envs.mjs && npm run build && node scripts/run-playwright.mjs tests/auth-flow.spec.ts",
    "test:e2e:auth:local": "node scripts/check-supabase-envs.mjs && node scripts/playwright-auth-local.mjs",
    "check:env:supabase": "node scripts/check-supabase-envs.mjs",
    "smoke:check": "node scripts/smoke-check.mjs",
    "smoke:i18n": "node scripts/smoke-i18n.mjs",
    "logs:tail": "node scripts/tail-logs.mjs",
    "ops:health-report": "node scripts/ops-health-report.mjs",
    "ops:backup-verify": "node scripts/backup-verify.mjs",
    "ops:backup-verify-remote": "node scripts/backup-verify-remote.mjs",
    "py:catalog:enrich": "cd tools/python && uv run python scripts/catalog_enrich.py --dry-run",
    "py:ops:report": "cd tools/python && uv run python scripts/ops_report.py --output ../../docs/python-ops-report.md",
    "py:scrapy:registry": "cd tools/python && uv run scrapy crawl mcp_registry -O ../../docs/mcp-registry-scrapy.json"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "gpt-tokenizer": "^2.9.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.35.0",
    "next": "16.1.6",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.1",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5"
  }
}
